# ── Required ─────────────────────────────────────────────────────────────
# Anthropic API key — powers taste-matching, cover-photo identification, and
# typo/description search rescue. All LLM calls happen server-side.
ANTHROPIC_API_KEY=

# Secret used to sign the session cookie. Any long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional ─────────────────────────────────────────────────────────────
# Model used for recommendations / vision / search rescue. Defaults to Opus 4.8.
ANTHROPIC_MODEL=claude-opus-4-8

# Google Books API key. Without it the app falls back to the unauthenticated
# Google Books endpoint (lower quota) and then Open Library.
GOOGLE_BOOKS_API_KEY=

# Amazon Associates tag — appended to product links when present.
AMAZON_AFFILIATE_TAG=
